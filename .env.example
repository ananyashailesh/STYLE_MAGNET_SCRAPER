# APIFY
APIFY_TOKEN=           # From apify.com → Settings → Integrations
APIFY_DATASET_ID=      # Dataset ID from your Apify actor run

# SUPABASE
SUPABASE_URL=          # From Supabase → Settings → API
SUPABASE_KEY=          # Service role key (not anon key) from Supabase

# OPENROUTER (LLM fallback for normalization)
OPENROUTER_API_KEY=    # Free at openrouter.ai — used only as LLM fallback
